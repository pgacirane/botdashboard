<?xml version="1.0" encoding="UTF-8"?>
<web-app version="4.0" xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd">

    <!-- ══ FILTERS ══════════════════════════════════════════════════════════ -->
    <filter>
        <filter-name>home_dashboard</filter-name>
        <filter-class>templates.AiBotsDashboardTemplate</filter-class>
    </filter>
    <filter>
        <filter-name>BotViewerFilter</filter-name>
        <filter-class>templates.BotViewerTemplate</filter-class>
    </filter>

    <!-- ══ FILTER MAPPINGS ══════════════════════════════════════════════════ -->
    <filter-mapping>
        <filter-name>home_dashboard</filter-name>
        <url-pattern>/AiBotsDashboard</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>home_dashboard</filter-name>
        <url-pattern>/SocialImpact</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>home_dashboard</filter-name>
        <url-pattern>/AIEthics</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>home_dashboard</filter-name>
        <url-pattern>/Etymology</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>BotViewerFilter</filter-name>
        <url-pattern>/BotViewer</url-pattern>
    </filter-mapping>

    <!-- ══ SERVLETS ═════════════════════════════════════════════════════════
         RULE: @WebServlet annotation OR web.xml — NEVER both.
         BotViewer.java, ChatServlet.java, LoadArchitectureDiagram.java
         all use @WebServlet — NOT declared here.
    ════════════════════════════════════════════════════════════════════════ -->
    <servlet>
        <servlet-name>AiBotsDashboard</servlet-name>
        <jsp-file>/WEB-INF/dashboard_viewer/AibBotsDashboard.jsp</jsp-file>
    </servlet>
    <servlet>
        <servlet-name>SocialImpactServlet</servlet-name>
        <servlet-class>servlets.SocialImpactServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AIEthicsServlet</servlet-name>
        <servlet-class>servlets.AIEthicsServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AIonifierEtymologyServlet</servlet-name>
        <servlet-class>servlets.AIonifierEtymologyServlet</servlet-class>
    </servlet>

    <!-- ══ SERVLET MAPPINGS ═════════════════════════════════════════════════ -->
    <servlet-mapping>
        <servlet-name>AiBotsDashboard</servlet-name>
        <url-pattern>/AiBotsDashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SocialImpactServlet</servlet-name>
        <url-pattern>/SocialImpact</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AIEthicsServlet</servlet-name>
        <url-pattern>/AIEthics</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AIonifierEtymologyServlet</servlet-name>
        <url-pattern>/Etymology</url-pattern>
    </servlet-mapping>

    <!-- ══ SESSION ══════════════════════════════════════════════════════════ -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

</web-app>